{
	"name": "cliffparnitzky/direct-content-elements",
	"description": "Directly lists all content elements of articles, news and events. Provides the possibility to edit content elements across parent containers (multi-editing).",
	"keywords": [
		"contao",
		"backend",
		"multi edit",
		"content elements"
	],
	"type": "contao-bundle",
	"license": "LGPL-3.0-or-later",
	"authors": [
		{
			"name": "Cliff Parnitzky",
			"email": "contao@cliff-parnitzky.de",
			"role": "Developer"
		}
	],
	"support": {
		"email": "contao@cliff-parnitzky.de",
		"issues": "https://github.com/cliffparnitzky/DirectContentElements/issues",
		"source": "https://github.com/cliffparnitzky/DirectContentElements"
	},
	"require": {
		"php": "^8.3",
		"contao/core-bundle": "^5.3"
	},
	"require-dev": {
		"contao/manager-plugin": "^2.12"
	},
	"autoload": {
		"psr-4": {
			"CliffParnitzky\\DirectContentElements\\": "src/"
		},
		"classmap": [
			"contao/"
		],
		"exclude-from-classmap": [
			"contao/dca/",
			"contao/languages/"
		]
	},
	"config": {
		"allow-plugins": {
			"contao-components/installer": false,
			"contao/manager-plugin": false,
			"contao-community-alliance/composer-plugin": true
		}
	},
	"extra": {
		"contao-manager-plugin": "CliffParnitzky\\DirectContentElements\\ContaoManager\\Plugin"
	}
}